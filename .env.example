# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# Get your connection string from your database provider (e.g., Supabase, Neon, Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:port/database"

# ==========================================
# Caching & Rate Limiting (Redis / Upstash)
# ==========================================
# Create a Redis database at https://upstash.com/ to get these keys
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
# If using ioredis, use the standard Redis connection string (TCP) instead of REST
REDIS_URL="rediss://default:password@your-upstash-endpoint.upstash.io:6379"

# ==========================================
# Authentication (Better Auth)
# ==========================================
# The base URL of your application (e.g., http://localhost:3000 in development)
BETTER_AUTH_URL="http://localhost:3000"
# Generate a random secret using: openssl rand -base64 32
BETTER_AUTH_SECRET="your-random-secret-key-here"

# Superadmin Configuration
# Comma-separated list of emails that should be granted superadmin privileges
ADMIN_EMAILS="admin@yourdomain.com,founder@yourdomain.com"

# ==========================================
# Payments (Stripe)
# ==========================================
# Get these keys from your Stripe Developer Dashboard: https://dashboard.stripe.com/apikeys
# Secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY="sk_test_..."
# Publishable key (starts with pk_test_ or pk_live_) - exposed to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook secret for local testing (use Stripe CLI) or from webhook settings in dashboard
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==========================================
# Email Service (Resend)
# ==========================================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY="re_..."
# The email address that emails are sent from (must be a verified domain in Resend)
FROM_EMAIL="SaaSStarter <onboarding@resend.dev>"

# ==========================================
# Analytics (PostHog)
# ==========================================
# Your PostHog Project API Key
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# Your PostHog host (e.g., https://app.posthog.com or https://eu.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ==========================================
# Application Configuration
# ==========================================
# Public URL of the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Admin Setup Secret
# ==========================================
# Required during first-time admin setup. Generate with: openssl rand -base64 32
ADMIN_SETUP_SECRET="change-me-to-a-random-secret"

# ==========================================
# Stripe Product Configuration
# ==========================================
# Stripe Price IDs for different tiers (Get these from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID="price_..."
